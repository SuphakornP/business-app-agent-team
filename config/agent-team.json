{
  "modelProfiles": {
    "free": {
      "description": "Use the configured Pi GPT-5.5 model with lower thinking for routine planning and lightweight work.",
      "efforts": {
        "low": "openai-codex/gpt-5.5:low",
        "medium": "openai-codex/gpt-5.5:medium",
        "high": "openai-codex/gpt-5.5:high"
      }
    },
    "balanced": {
      "description": "Use GPT-5.5 through Pi for normal project work.",
      "efforts": {
        "low": "openai-codex/gpt-5.5:medium",
        "medium": "openai-codex/gpt-5.5:high",
        "high": "openai-codex/gpt-5.5:xhigh"
      }
    },
    "strong": {
      "description": "Use GPT-5.5 xhigh through Pi for architecture, implementation, and review.",
      "efforts": {
        "low": "openai-codex/gpt-5.5:high",
        "medium": "openai-codex/gpt-5.5:xhigh",
        "high": "openai-codex/gpt-5.5:xhigh"
      }
    }
  },
  "roles": {
    "supervisor-orchestrator": {
      "prompt": "supervisor.md",
      "defaultTier": "strong",
      "defaultEffort": "high",
      "models": {
        "free": "openai-codex/gpt-5.5:high",
        "balanced": "openai-codex/gpt-5.5:xhigh",
        "strong": "openai-codex/gpt-5.5:xhigh"
      }
    },
    "discovery-analyst": {
      "prompt": "discovery-analyst.md",
      "defaultTier": "free",
      "defaultEffort": "medium"
    },
    "product-manager": {
      "prompt": "product-manager.md",
      "defaultTier": "balanced",
      "defaultEffort": "medium"
    },
    "ux-flow-designer": {
      "prompt": "ux-flow-designer.md",
      "defaultTier": "balanced",
      "defaultEffort": "medium"
    },
    "solution-architect": {
      "prompt": "solution-architect.md",
      "defaultTier": "strong",
      "defaultEffort": "high"
    },
    "data-modeler": {
      "prompt": "data-modeler.md",
      "defaultTier": "strong",
      "defaultEffort": "medium"
    },
    "qa-risk-reviewer": {
      "prompt": "qa-risk-reviewer.md",
      "defaultTier": "strong",
      "defaultEffort": "medium"
    },
    "implementation-worker": {
      "prompt": "implementation-worker.md",
      "defaultTier": "strong",
      "defaultEffort": "high"
    },
    "code-reviewer": {
      "prompt": "code-reviewer.md",
      "defaultTier": "strong",
      "defaultEffort": "high"
    }
  },
  "presets": {
    "auto": {
      "description": "Resolve preset from current phase.",
      "phase": "current",
      "agents": []
    },
    "discovery": {
      "description": "Clarify the problem, real workflow, risks, questions, and use cases.",
      "phase": "discovery",
      "agents": [
        "discovery-analyst"
      ]
    },
    "planning": {
      "description": "Create scope and requirements, then review ambiguity.",
      "phase": "scope",
      "agents": [
        "product-manager",
        "qa-risk-reviewer"
      ]
    },
    "flow": {
      "description": "Create user journeys, screen flows, and state coverage.",
      "phase": "flow",
      "agents": [
        "ux-flow-designer",
        "qa-risk-reviewer"
      ]
    },
    "blueprint": {
      "description": "Create architecture, API, permission, and data model artifacts.",
      "phase": "blueprint",
      "agents": [
        "solution-architect",
        "data-modeler",
        "qa-risk-reviewer"
      ]
    },
    "implementation": {
      "description": "Run implementation and code review after blueprint approval.",
      "phase": "implementation",
      "agents": [
        "implementation-worker",
        "code-reviewer"
      ]
    },
    "review": {
      "description": "Run QA and code review against current delivery evidence.",
      "phase": "qa",
      "agents": [
        "qa-risk-reviewer",
        "code-reviewer"
      ]
    }
  }
}
