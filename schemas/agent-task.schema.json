{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/business-app-agent-team/agent-task.schema.json",
  "title": "Agent Task",
  "type": "object",
  "required": [
    "id",
    "phase",
    "agent",
    "goal",
    "expected_artifacts",
    "done_criteria",
    "approval_gate"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^T[0-9]{3,}$"
    },
    "phase": {
      "type": "string",
      "enum": [
        "intake",
        "discovery",
        "scope",
        "flow",
        "requirements",
        "blueprint",
        "implementation-plan",
        "implementation",
        "qa",
        "delivery"
      ]
    },
    "agent": {
      "type": "string"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "expected_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "done_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "approval_gate": {
      "type": "object",
      "required": [
        "required",
        "reason"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
