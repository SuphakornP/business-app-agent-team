{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/business-app-agent-team/approval-request.schema.json",
  "title": "Approval Request",
  "type": "object",
  "required": [
    "id",
    "phase",
    "requested_by",
    "decision_needed",
    "reason",
    "impact",
    "options",
    "recommended_option",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^APR-[0-9]{3,}$"
    },
    "phase": {
      "type": "string"
    },
    "requested_by": {
      "type": "string"
    },
    "decision_needed": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "impact": {
      "type": "string"
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "recommended_option": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "requested",
        "approved",
        "rejected",
        "cancelled"
      ]
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    },
    "resolved_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
