{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/business-app-agent-team/phase-status.schema.json",
  "title": "Phase Status",
  "type": "object",
  "required": [
    "phase",
    "status",
    "gate",
    "artifacts",
    "risks",
    "open_questions",
    "approval"
  ],
  "properties": {
    "phase": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "blocked",
        "needs_approval",
        "closed"
      ]
    },
    "gate": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approval": {
      "type": "object",
      "required": [
        "required",
        "status"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "not_required",
            "requested",
            "approved",
            "rejected"
          ]
        }
      },
      "additionalProperties": false
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
